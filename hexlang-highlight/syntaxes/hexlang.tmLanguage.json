{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Hexlang",
	"patterns": [
		{
			"include": "#keywords"
		},
		{
			"include": "#strings"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [{
				"name": "keyword.control.hexlang",
				"match": "\\b(if|while|for|return|let|const|elif|else|when|in|del|function|class)\\b"
			}]
		},
		"strings": {
			"name": "string.quoted.double.hexlang",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.hexlang",
					"match": "\\\\."
				}
			]
		},
        "comment": {
            "patterns": [
                {
                    "name": "comment.line.double-slash",
                    "match": "\\#.*"
                }
            ]
        }
	},
	"scopeName": "source.hexlang"
}